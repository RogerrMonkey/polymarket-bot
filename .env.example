# =====================================================================
# Polymarket Bot - environment template
# Copy to \.env\ and fill in. NEVER commit a real .env to source control.
# =====================================================================

# ---------------------------------------------------------------------
# Analyst (LLM provider)
# ---------------------------------------------------------------------
# Priority: nvidia -> deterministic stub.
# Set ANALYST_PROVIDER to force a specific provider.
ANALYST_PROVIDER=nvidia

# NVIDIA NIM - Primary analyst (free, 100+ models, no credit card)
# Get key: build.nvidia.com -> Developer Program -> API Keys
NVIDIA_API_KEY=
NVIDIA_MODEL=minimaxai/minimax-m2.7
NVIDIA_TEMPERATURE=0.6
NVIDIA_MAX_TOKENS=4096

# ---------------------------------------------------------------------
# Bot Configuration
# ---------------------------------------------------------------------
BOT_MIN_VOLUME=200.0
BOT_MIN_LIQUIDITY=200.0
BOT_MAX_SPREAD=0.05
BOT_LLM_ENABLED=true
BOT_ENABLE_POLYMARKET=true
LIVE_MODE=false
